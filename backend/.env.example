# --- Server ---
PORT=4000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:5173

# --- Postgres (pgvector) ---
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
# SSL is auto-enabled for non-localhost databases (Neon/Render/Supabase).
# Override if needed: true forces TLS, false disables it.
# DATABASE_SSL=true

# --- Deployment (mostly for hosted/production; safe to leave unset locally) ---
# NODE_ENV=production      # in production, AUTO_MIGRATE + SERVE_FRONTEND default to on
# AUTO_MIGRATE=true        # apply db/schema.sql on startup (idempotent)
# SERVE_FRONTEND=true      # serve the built React app from this API (single-service deploy)

# --- OpenAI ---
# If OPENAI_API_KEY is empty, Atlas runs in OFFLINE MOCK mode:
#   * deterministic local embeddings (no network)
#   * a template-based synthesizer that still produces grounded, cited answers
# This lets you run the full pipeline end-to-end without any API key.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Must match the vector(N) dimension in db/schema.sql (1536 for text-embedding-3-small)
EMBEDDING_DIM=1536

# --- RAG tuning ---
CHUNK_SIZE=900          # target characters per chunk
CHUNK_OVERLAP=150       # overlap characters between chunks
RETRIEVE_TOP_K=6        # chunks retrieved per sub-query
