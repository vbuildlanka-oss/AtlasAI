# --- Server ---
PORT=4000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:5173

# --- Postgres (pgvector) ---
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
# SSL is auto-enabled for non-localhost databases (Neon/Render/Supabase).
# Override if needed: true forces TLS, false disables it.
# DATABASE_SSL=true

# --- Deployment (mostly for hosted/production; safe to leave unset locally) ---
# NODE_ENV=production      # in production, AUTO_MIGRATE + SERVE_FRONTEND default to on
# AUTO_MIGRATE=true        # apply db/schema.sql on startup (idempotent)
# SERVE_FRONTEND=true      # serve the built React app from this API (single-service deploy)

# --- AI providers ---------------------------------------------------------
# Chat (planning + answer writing) and embeddings (search) are chosen
# independently. If nothing is set, Atlas runs fully OFFLINE:
#   * deterministic local embeddings (no network)
#   * a template synthesizer that still produces grounded, cited answers
#
# Resolution order:
#   Chat:       GROQ_API_KEY  ->  OPENAI_API_KEY  ->  offline mock
#   Embeddings: OPENAI_API_KEY (Groq has no embeddings) -> offline mock

# Option A) FREE real AI for the answers via Groq (no credit card).
# Get a key at https://console.groq.com/keys — search stays on the local
# embedder, so no vector-dimension changes and no re-ingesting needed.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # default; rarely needs changing

# Option B) OpenAI for BOTH smarter search (embeddings) and answers.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=                                # for OpenAI-compatible gateways

# Must match the vector(N) dimension in db/schema.sql.
# 1536 fits both the offline mock embedder and OpenAI text-embedding-3-small.
EMBEDDING_DIM=1536

# --- RAG tuning ---
CHUNK_SIZE=900          # target characters per chunk
CHUNK_OVERLAP=150       # overlap characters between chunks
RETRIEVE_TOP_K=6        # chunks retrieved per sub-query
